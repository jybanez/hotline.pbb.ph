      "glyphs": "https://mapserver.pbb.ph/tiles/glyphs/{fontstack}/{range}.pbf",
      "poi": "https://mapserver.pbb.ph/tiles/poi/{z}/{x}/{y}.pbf"
    },
    "poi": {
      "enabled": true,
      "sourceLayers": ["poi", "pois", "point", "points", "amenity"],
      "excludedClasses": []
    }
  }
