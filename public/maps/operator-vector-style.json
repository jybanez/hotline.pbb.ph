{
  "version": 8,
  "name": "Hotline Dark Vector",
  "sources": {
    "osm": {
      "type": "vector",
      "tiles": [
        "https://mapserver.pbb.ph/tiles/vector/{z}/{x}/{y}.pbf"
      ],
      "minzoom": 0,
      "maxzoom": 14
    },
    "terrain": {
      "type": "raster-dem",
      "tiles": [
        "https://mapserver.pbb.ph/tiles/terrain/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "encoding": "mapbox",
      "minzoom": 0,
      "maxzoom": 12
    },
    "terrain-hillshade": {
      "type": "raster-dem",
      "tiles": [
        "https://mapserver.pbb.ph/tiles/terrain/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "encoding": "mapbox",
      "minzoom": 0,
      "maxzoom": 12
    }
  },
  "glyphs": "https://mapserver.pbb.ph/tiles/glyphs/{fontstack}/{range}.pbf",
  "terrain": {
    "source": "terrain",
    "exaggeration": 1.15
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#000000"
      }
    },
    {
      "id": "terrain-hillshade",
      "type": "hillshade",
      "source": "terrain-hillshade",
      "paint": {
        "hillshade-shadow-color": "#0a1118",
        "hillshade-highlight-color": "#1b2b3a",
        "hillshade-accent-color": "#121f2b"
      }
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "osm",
      "source-layer": "landcover",
      "paint": {
        "fill-color": "#0b141b",
        "fill-opacity": 1
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "osm",
      "source-layer": "landuse",
      "paint": {
        "fill-color": "#0f1b25",
        "fill-opacity": 0.85
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "osm",
      "source-layer": "water",
      "paint": {
        "fill-color": "#0d2533",
        "fill-opacity": 0.95
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "osm",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#184156",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          8,
          0.4,
          14,
          1.4
        ],
        "line-opacity": 0.9
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "osm",
      "source-layer": "building",
      "minzoom": 12,
      "paint": {
        "fill-color": "#162431",
        "fill-opacity": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          12,
          0.2,
          14,
          0.35,
          16,
          0.55
        ]
      }
    },
    {
      "id": "buildings-outline",
      "type": "line",
      "source": "osm",
      "source-layer": "building",
      "minzoom": 12,
      "paint": {
        "line-color": "#2a4153",
        "line-opacity": 0.8,
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          12,
          0.3,
          14,
          0.7,
          16,
          1.1
        ]
      }
    },
    {
      "id": "roads",
      "type": "line",
      "source": "osm",
      "source-layer": "transportation",
      "paint": {
        "line-color": "#3b4b5a",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          5,
          0.5,
          12,
          1.5,
          16,
          3
        ]
      }
    },
    {
      "id": "boundaries",
      "type": "line",
      "source": "osm",
      "source-layer": "boundary",
      "paint": {
        "line-color": "#223140",
        "line-width": 1,
        "line-opacity": 0.6
      }
    },
    {
      "id": "road-labels",
      "type": "symbol",
      "source": "osm",
      "source-layer": "transportation_name",
      "layout": {
        "symbol-placement": "line",
        "text-field": [
          "coalesce",
          [
            "get",
            "name_en"
          ],
          [
            "get",
            "name"
          ]
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          10,
          10,
          14,
          12,
          16,
          14
        ],
        "text-font": [
          "Open Sans Regular",
          "Arial Unicode MS Regular"
        ]
      },
      "paint": {
        "text-color": "#8ea1b4",
        "text-halo-color": "#0b141b",
        "text-halo-width": 1
      }
    },
    {
      "id": "place-labels",
      "type": "symbol",
      "source": "osm",
      "source-layer": "place",
      "layout": {
        "text-field": [
          "coalesce",
          [
            "get",
            "name_en"
          ],
          [
            "get",
            "name"
          ]
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          5,
          8,
          10,
          11,
          14,
          13
        ],
        "text-font": [
          "Open Sans Semibold",
          "Arial Unicode MS Regular"
        ]
      },
      "paint": {
        "text-color": "#c7d4e0",
        "text-halo-color": "#0b141b",
        "text-halo-width": 1.2
      }
    }
  ]
}
