APP_NAME="PBB Hotline Beta"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://hotline.pbb.ph

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pbb_hotline
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=15
HOTLINE_CITIZEN_SESSION_LIFETIME=43200
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

PBB_ACCOUNT_SSO_ENABLED=true
PBB_ACCOUNT_BASE_URL=https://account.pbb.ph
PBB_ACCOUNT_CLIENT_ID=pbb-hotline
PBB_ACCOUNT_CLIENT_SECRET=pbb-hotline-dev-secret
PBB_ACCOUNT_REDIRECT_URI=https://hotline.pbb.ph/auth/account/callback
PBB_ACCOUNT_POST_LOGOUT_REDIRECT_URI=https://hotline.pbb.ph
PBB_ACCOUNT_SCOPES="openid profile"
PBB_ACCOUNT_TIMEOUT_SECONDS=10
PBB_ACCOUNT_CA_BUNDLE=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_APP_URL="${APP_URL}"
MEDIA_ASSEMBLY_TOKEN=local-media-assembly-token
HOTLINE_FFMPEG_BINARY=
HOTLINE_FFPROBE_BINARY=
HOTLINE_REALTIME_CA_BUNDLE=
RELAY_HUB_JSON_URL=https://relay.pbb.ph/hub.json
RELAY_HUB_JSON_TIMEOUT=5
